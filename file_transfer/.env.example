# =============================================================================
# File Transfer Automation - Environment Configuration Template
# Copy this file to `.env` (in the same directory) and fill in your credentials.
#   cp .env.example .env      (macOS / Linux)
#   copy .env.example .env    (Windows / PowerShell)
# NEVER commit your real `.env` to source control.
# =============================================================================

# ---- General ----
LOG_LEVEL=INFO

# ---- Watch Folder ----
# The folder to monitor for new files (created automatically if missing).
WATCH_FOLDER=

# ---- Slack ----
# Bot token: https://api.slack.com/apps → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=
# Channel ID or user ID to send the file to.
SLACK_CHANNEL=

# ---- Dropbox (desktop sync) ----
# Install "Dropbox" and point this to the sync folder.
# Typical path: C:\Users\<you>\Dropbox\Uploads
DROPBOX_SYNC_FOLDER=

# ---- SFTP ----
SFTP_HOST=
SFTP_PORT=22
SFTP_USERNAME=
SFTP_PASSWORD=
# Optional: path to an SSH private key instead of password.
SFTP_PRIVATE_KEY=
SFTP_REMOTE_DIR=/uploads

# ---- Local / Network Copy ----
LOCAL_COPY_DEST=

# ---- Microsoft Teams ----
# Register an Azure AD app with ChannelMessage.Send + Files.ReadWrite.All
TEAMS_TENANT_ID=
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=
TEAMS_TEAM_ID=
TEAMS_CHANNEL_ID=

# ---- WhatsApp (via Twilio) ----
# https://www.twilio.com/console → Account SID & Auth Token
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
WHATSAPP_FROM_NUMBER=
WHATSAPP_TO_NUMBER=
# Public URL where files can be temporarily fetched by Twilio (e.g. ngrok URL)
WHATSAPP_MEDIA_BASE_URL=

# ---- Telegram ----
# Talk to @BotFather on Telegram to create a bot and get the token.
TELEGRAM_BOT_TOKEN=
# Chat ID: send a message to the bot, then visit
# https://api.telegram.org/bot<TOKEN>/getUpdates to find the chat ID.
TELEGRAM_CHAT_ID=

# ---- Zoom ----
# Create a Server-to-Server OAuth app in the Zoom Marketplace.
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_CHAT_CHANNEL_ID=

# ---- Box (desktop sync) ----
# Install "Box Drive" and point this to the sync folder.
# Typical path: C:\Users\<you>\Box\Uploads
BOX_SYNC_FOLDER=

# ---- OneDrive (desktop sync) ----
# OneDrive is built into Windows. Point to your sync folder.
# Typical path: C:\Users\<you>\OneDrive\Uploads
ONEDRIVE_SYNC_FOLDER=

# ---- iCloud (desktop sync) ----
# Install "iCloud for Windows" and enable iCloud Drive.
# Typical path: C:\Users\<you>\iCloudDrive\Uploads
ICLOUD_SYNC_FOLDER=

# ---- WeTransfer (Playwright + MailSlurp) ----
WETRANSFER_RECIPIENT_EMAIL=
WETRANSFER_SENDER_EMAIL=
MAILSLURP_API_KEY=
WETRANSFER_HEADLESS=true
WETRANSFER_DEBUG=false
